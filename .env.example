# =============================================
#   DigitalHub Multi-Plataforma — .env
# =============================================

# --- Servidor ---
PORT=3000
NODE_ENV=production
BASE_URL=https://seudominio.com

# --- Segurança: Secrets dos Webhooks ---
# Kiwify: encontre em Kiwify > Configurações > Webhooks > Token secreto
KIWIFY_WEBHOOK_SECRET=seu_token_kiwify_aqui

# Yampi: encontre em Yampi > Configurações > Webhooks > Chave secreta
YAMPI_WEBHOOK_SECRET=seu_token_yampi_aqui

# Fallback geral (usado se os acima não estiverem definidos)
WEBHOOK_SECRET=fallback_secreto_aqui

# --- Banco de Dados ---
DB_PATH=./data/digitalhub.db

# --- Uploads ---
UPLOADS_PATH=./uploads
MAX_FILE_SIZE_MB=50

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@email.com
SMTP_PASS=sua_app_password_gmail
EMAIL_FROM_NAME=Minha Loja Digital
EMAIL_FROM_ADDRESS=seu@email.com

# --- Retry automático ---
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=60
